<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app">

    <LinearLayout
        android:id="@+id/cabezeraLay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/fondo_app"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnAtras"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/fondo_app"
            android:src="@drawable/baseline_arrow_back_ios_new_24"
            app:tint="@color/verde"
            android:layout_marginStart="10dp"/>

        <TextView
            android:id="@+id/tvTituloStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/estad_stiques_i_co2"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/black"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <View
        android:id="@+id/lineaLay"
        android:layout_width="match_parent"
        android:background="@color/verde"
        android:layout_height="5dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/cabezeraLay"/>

    <TextView
        android:id="@+id/tvCo2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/co2_0_0kg"
        android:gravity="center"
        android:textSize="20sp"
        android:textColor="@color/verde"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/lineaLay" />

    <com.github.mikephil.charting.charts.BarChart
        android:id="@+id/barChartFiltros"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        app:layout_constraintTop_toBottomOf="@id/tvCo2"
        android:layout_marginTop="10dp"/>

    <com.github.mikephil.charting.charts.PieChart
        android:id="@+id/pieChartReviews"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        app:layout_constraintTop_toBottomOf="@id/barChartFiltros"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reset_estad_stiques"
        android:backgroundTint="@color/verde"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>